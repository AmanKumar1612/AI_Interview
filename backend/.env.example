# ─── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/ai_interview?retryWrites=true&w=majority

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# ─── LLM Provider ─────────────────────────────────────────
# Options: groq | openai | gemini
LLM_PROVIDER=groq

# Groq (https://console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama3-70b-8192

# OpenAI (use if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# Google Gemini (use if LLM_PROVIDER=gemini)
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-1.5-pro

# ─── Email (Gmail + App Password) ────────────────────────
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM="AI Interview System <your.email@gmail.com>"

# ─── Frontend URL (CORS) ─────────────────────────────────
CLIENT_URL=http://localhost:5173
